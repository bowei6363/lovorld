# ============================================================================
# lovorld environment variables
# Copy this file to .env.local for local development. Never commit secrets.
# ============================================================================

# --- App ---
# Public URL where the app is reachable (used for OAuth callbacks, OG tags).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Database (PostgreSQL with pgvector) ---
# Recommended: Supabase or Neon. Must have pgvector extension enabled.
DATABASE_URL="postgres://user:password@host:5432/lovorld"

# --- Auth (NextAuth.js v5 / Auth.js) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# OAuth providers (optional, enable as needed)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Object storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="lovorld-images"
# Public CDN host for serving uploaded images.
R2_PUBLIC_URL="https://images.lovorld.example"

# --- AI: DeepSeek (image -> structured description) ---
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=""
DEEPSEEK_VISION_MODEL="deepseek-vl2"

# --- AI: text embedding (description -> vector) ---
# Choose ONE provider; the ImageFeatureProvider impl will use whichever is set.
# Option A: Voyage AI (recommended for multilingual/image-domain text)
VOYAGE_API_KEY=""
VOYAGE_EMBED_MODEL="voyage-3-large"

# Option B: OpenAI text-embedding-3
OPENAI_API_KEY=""
OPENAI_EMBED_MODEL="text-embedding-3-large"

# --- Monitoring (optional, fill in for prod) ---
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
